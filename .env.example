# Agentplane environment configuration
# Copy this file to .env and fill in your values.
# Variables are loaded automatically because SettingsConfigDict uses env_file=".env".

# Server
AGENTPLANE_HOST=127.0.0.1
AGENTPLANE_PORT=3400

# Database — SQLite by default for zero-config local development
AGENTPLANE_DATABASE_URL=sqlite:///./data/agentplane.db

# Local data directory
AGENTPLANE_DATA_DIR=./data

# Agent execution
AGENTPLANE_DEFAULT_AGENT_TIMEOUT=300
AGENTPLANE_DEFAULT_GRACE_PERIOD=20

# Logging
AGENTPLANE_LOG_LEVEL=INFO
AGENTPLANE_DEBUG=false

# OANDA credentials (recommended: keep secrets here, not in agent adapter_config)
# 1. Open a demo account at https://www.oanda.com/demo-account/ (or use a live account).
# 2. Create an API token in the OANDA portal: Manage API Access → Generate token.
# 3. Find your account ID:
#    - In the OANDA web platform it is shown as the "v20 Account Number" (format: ###-###-########-###).
#    - Or call the API once you have a token:
#        curl -H "Authorization: Bearer <TOKEN>" https://api-fxpractice.oanda.com/v3/accounts
#      The response contains {"accounts": [{"id": "101-...-001"}, ...]}.
#    - Use the practice URL above for demo accounts; live accounts use https://api-fxtrade.oanda.com/v3/accounts.
AGENTPLANE_OANDA_TOKEN=your_oanda_token_here
AGENTPLANE_OANDA_ACCOUNT_ID=your_oanda_account_id_here
